{
  "expo": {
    "name": "GamePay",
    "slug": "gamepay",
    "version": "1.0.0",
    "scheme": "gamepay",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFA800"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gamepay.app",
      "associatedDomains": [
        "applinks:gamepay.app"
      ],
      "infoPlist": {
        "NSCameraUsageDescription": "GamePay butuh akses kamera untuk scan QR code group order dan QRIS pembayaran.",
        "NSPhotoLibraryUsageDescription": "GamePay butuh akses galeri untuk mengubah foto profil kamu.",
        "LSApplicationQueriesSchemes": [
          "gojek",
          "ovo",
          "dana",
          "shopeeid",
          "linkaja"
        ]
      }
    },
    "android": {
      "package": "com.gamepay.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFA800"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.RECORD_AUDIO"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "gamepay.app",
              "pathPrefix": "/join"
            },
            {
              "scheme": "gamepay"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "GamePay butuh akses galeri untuk mengubah foto profil kamu."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#FFA800",
          "defaultChannel": "default"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "b3ad01b0-6dbf-4f47-9cae-192a6512b158"
      }
    },
    "owner": "valentwemens-organization"
  }
}
